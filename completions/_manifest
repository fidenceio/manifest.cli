#compdef manifest
# Zsh completion for Manifest CLI.
# Install: copy or symlink this file into a directory on $fpath named '_manifest',
# then run `compinit`. Homebrew puts user completions in /opt/homebrew/share/zsh/site-functions/.

_manifest_keys() {
    local -a keys
    if [[ -z "${_MANIFEST_ZSH_KEYS_CACHE:-}" ]]; then
        _MANIFEST_ZSH_KEYS_CACHE="$(manifest config list 2>/dev/null | awk 'NR>2 && $1!="" {print $1}' | sort -u)"
    fi
    keys=(${(f)_MANIFEST_ZSH_KEYS_CACHE})
    _describe 'config keys' keys
}

_manifest() {
    local -a top_cmds
    top_cmds=(
        'config:Setup wizard / show configuration'
        'init:Scaffold a repo or fleet'
        'quickstart:Run an opinionated quickstart workflow'
        'plan:Generate an adoption plan'
        'reconcile:Validate and apply an adoption plan'
        'status:Read-only snapshot'
        'recipe:Inspect workflow recipes'
        'discover:Discover resources without writing changes'
        'update:Update fleet membership'
        'add:Add a resource to Manifest-managed configuration'
        'validate:Validate fleet configuration'
        'prep:Connect remotes, pull latest'
        'refresh:Regenerate docs and metadata'
        'docs:Generate fleet documentation'
        'ship:Publish a release (version + tag + push)'
        'pr:Pull-request operations (gh wrapper)'
        'doctor:Health check'
        'security:Security audit'
        'upgrade:Update Manifest CLI'
        'uninstall:Remove Manifest CLI'
        'version:Show CLI version'
        'help:Show help'
    )

    local -a scopes bumps config_subs pr_subs recipe_subs layers
    scopes=(repo fleet)
    bumps=(patch minor major revision)
    config_subs=(show list get set unset describe doctor setup time)
    pr_subs=(create status checks ready merge update queue policy fleet help)
    recipe_subs=(list show explain help)
    layers=(global project local)

    _arguments -C \
        '1: :->command' \
        '2: :->subcommand' \
        '3: :->arg3' \
        '*::extra:->extra'

    case $state in
        command)
            _describe 'command' top_cmds
            ;;
        subcommand)
            case $words[2] in
                init|quickstart|plan|reconcile|discover|update|add|validate|prep|refresh|docs|ship)
                    _values 'scope' "${scopes[@]}"
                    ;;
                config)
                    _values 'config subcommand' "${config_subs[@]}"
                    ;;
                recipe)
                    _values 'recipe subcommand' "${recipe_subs[@]}"
                    ;;
                pr)
                    _values 'pr subcommand' "${pr_subs[@]}"
                    ;;
                uninstall)
                    _values 'option' -y --yes --dry-run --force --help
                    ;;
                reinstall)
                    _values 'option' -y --yes --dry-run --help
                    ;;
            esac
            ;;
        arg3)
            case "$words[2] $words[3]" in
                "init fleet")
                    _values 'option' -y --yes --depth --all-folders --force --dry-run --name --create-repo-private --create-repo-public --help
                    ;;
                "ship repo"|"ship fleet")
                    _values 'release type / option' "${bumps[@]}" -y --yes --local --dry-run --explain -i --interactive --only --except --noprep
                    ;;
                "plan fleet")
                    _values 'option' --apply --do --dry-run --depth --safety-cap --plan --name --force --help
                    ;;
                "reconcile fleet")
                    _values 'option' --apply --do --dry-run --plan --commit --push --force --adopt-submodules --help
                    ;;
                "pr create")
                    _values 'option' -y --yes --dry-run --draft --title --body --base --labels --reviewers --help
                    ;;
                "pr ready"|"pr merge"|"pr update"|"pr queue")
                    _values 'option' -y --yes --dry-run --method --force --auto --squash --merge --rebase --help
                    ;;
                "pr fleet")
                    _values 'fleet PR subcommand / option' create status checks ready queue help -y --yes --dry-run --method --force --help
                    ;;
                "config get"|"config describe"|"config unset"|"config set")
                    _manifest_keys
                    ;;
                "config list")
                    _values 'option' --layer
                    ;;
            esac
            ;;
        extra)
            if [[ $words[$((CURRENT-1))] == "--layer" ]]; then
                _values 'layer' "${layers[@]}"
            else
                _values 'option' --help -y --yes --local --dry-run --explain --layer --fix --json
            fi
            ;;
    esac
}

_manifest "$@"
