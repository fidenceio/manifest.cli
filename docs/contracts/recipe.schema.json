{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://manifest.dev/schemas/manifest.recipe.schema.json",
  "title": "Manifest Recipe",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "title", "kind", "command", "scope", "execution", "inputs", "steps"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._-]*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "enum": ["builtin", "project"]
    },
    "command": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "string",
      "enum": ["repo", "fleet"]
    },
    "summary": {
      "type": "string"
    },
    "extends": {
      "type": "string"
    },
    "entrypoint": {
      "type": "string"
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["default_mode", "requires_yes_for"],
      "properties": {
        "default_mode": {
          "type": "string",
          "enum": ["preview", "apply"]
        },
        "requires_yes_for": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["local-write", "remote-write", "pr"]
          }
        }
      }
    },
    "inputs": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["string", "boolean", "enum"]
          },
          "default": {},
          "required": {
            "type": "boolean"
          },
          "values": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "uses", "effect"],
        "properties": {
          "id": {
            "type": "string"
          },
          "uses": {
            "type": "string"
          },
          "effect": {
            "type": "string",
            "enum": ["read", "local-write", "remote-write", "pr"]
          },
          "when": {
            "type": "string"
          },
          "with": {
            "type": "object"
          }
        }
      }
    }
  }
}
