# =============================================================================
# Manifest CLI — Project Configuration
# =============================================================================
# This file is committed to git and shared with your team.
# It defines how this project is versioned, tagged, documented, and released.
#
# Setup:
#   cp examples/manifest.config.yaml.example manifest.config.yaml
#
# Precedence (last wins):
#   1. Code defaults (set_default_configuration)
#   2. User global (~/.manifest-cli/manifest.config.global.yaml)
#   3. This file (manifest.config.yaml) — committed, shared
#   4. Local overrides (manifest.config.local.yaml) — git-ignored, personal
# =============================================================================

# -----------------------------------------------------------------------------
# Versioning
# -----------------------------------------------------------------------------
version:
  format: "XX.XX.XX"           # XX.XX.XX | XXXX.XXXX.XXXX | YYYY.MM.DD
  separator: "."
  components: "major,minor,patch"
  max_values: "0,0,0"          # 0 = unlimited
  regex: "^[0-9]+(\\.[0-9]+)*$"
  validation: true

  component_position:
    major: 1
    minor: 2
    patch: 3
    revision: 4

  increment_target:
    major: 1
    minor: 2
    patch: 3
    revision: 4

  reset_components:
    major: "2,3,4"
    minor: "3,4"
    patch: "4"
    revision: ""

# -----------------------------------------------------------------------------
# Release
# -----------------------------------------------------------------------------
# tag_target — which commit the release tag points at.
#
#   "version_commit" (default, since v44.10.1)
#       Tag the explicit "Bump version to X" commit.  Stays anchored to the
#       canonical release artifact even when a CHANGELOG commit lands after
#       the bump but before the tag is created.
#
#   "release_head"
#       Tag whatever HEAD is at tag-creation time (post-bump, post-CHANGELOG,
#       pre-Homebrew).  Note: the Homebrew formula commit cannot be inside
#       the tag — `update_homebrew_formula` curls the GitHub tarball at the
#       tag URL to compute SHA256, which would require the formula to contain
#       its own SHA256 (chicken-and-egg).  So `release_head` means "last
#       release-prep commit *before* Homebrew", not literally the final
#       commit of the release.
#
# Deprecated: "final_release_commit" — alias for "release_head", will warn.
# Tolerant of surrounding whitespace and case (Version_Commit, " release_head ").
release:
  canonical_repo_slugs: "fidenceio/manifest.cli,fidenceio/fidenceio.manifest.cli"
  tag_target: "version_commit"

  # gate — what must be green before a release is published.
  #   none         No verification. Loud warning + audited bypass.
  #   local-tests  (default) Run the test command before any version mutation;
  #                a failure aborts with the repo untouched.
  #   remote-ci    Require the pushed commit's GitHub checks to be green before
  #                the GitHub Release / Homebrew publish (tag is already pushed).
  #   all          local-tests AND remote-ci.
  # Tolerant of surrounding whitespace and case.
  gate: "local-tests"

  # gate_command — command run for the local-tests phase. Empty auto-detects
  # ./scripts/run-tests.sh. Set this to your project's test entrypoint, e.g.
  # "pytest -q", "go test ./...", "npm test", "make test".
  gate_command: ""

# -----------------------------------------------------------------------------
# Ship
# -----------------------------------------------------------------------------
ship:
  interactive: false           # Prompt during ship flows when running in a TTY.

# -----------------------------------------------------------------------------
# GitHub
# -----------------------------------------------------------------------------
github:
  release:
    enabled: true       # Create a matching GitHub Release after tag push.
    required: false     # If true, a GitHub Release failure fails the ship run.
    draft: false
    prerelease: false

# -----------------------------------------------------------------------------
# Git
# -----------------------------------------------------------------------------
git:
  tag_prefix: "v"
  tag_suffix: ""
  default_branch: "main"
  development_branch: "develop"
  staging_branch: "staging"
  feature_prefix: "feature/"
  hotfix_prefix: "hotfix/"
  release_prefix: "release/"
  bugfix_prefix: "bugfix/"
  commit_template: "Release v{version} - {timestamp}"
  push_strategy: "simple"
  pull_strategy: "rebase"
  timeout: 300
  retries: 3

# -----------------------------------------------------------------------------
# Documentation
# -----------------------------------------------------------------------------
docs:
  folder: "docs"
  archive_folder: "docs/zArchive"
  retain: "10 versions"       # How much archive history to keep. Active docs/
                              # always holds exactly the current version; the
                              # previous version moves to archive on every ship.
                              # `retain` controls the archive itself:
                              #   "N versions" - keep the N most recent archived
                              #                  versions; older ones are deleted
                              #   "N days"     - delete archived files older than
                              #                  N days (uses mtime)
                              #   "off"        - never delete; archive grows
                              # SECURITY_ANALYSIS_REPORT_v* files are point-in-time
                              # audits and are never auto-deleted.
  template_dir: ""
  generate:
    enabled: true
    changelog: true
    readme_version: true
    index: true
    archive_cleanup: true
    site: true
    site_workflow: true
  site:
    enabled: false
    enable_pages: true                # Best-effort; a Pages failure never interrupts the run
    source_dir: "docs-site"
    publish_mode: "actions"
    branding: "auto"
    theme: "manifest"
    title: ""
    description: ""
    custom_css: ""
    palette:
      primary: "#2563eb"
      accent: "#14b8a6"
      background: "#ffffff"
      surface: "#f8fafc"
      text: "#111827"
      muted: "#64748b"
  review:
    enabled: true
    outputs: "commit_body,report,release_notes"
    report_dir: ""          # Empty (default): write to .git/manifest-doc-review/, never committed.
                            # Set to a working-tree path (e.g., "docs/documentation-reviews")
                            # to opt in to committed reports.
    provider: "local"       # local | command
    command: ""             # Called as: command REPORT_FILE PROJECT_ROOT
    required: false         # Fail commit if provider fails
  release_notes:
    # Per-ship release-notes synthesis. Manifest builds a request file
    # (metadata + cleaned commit subjects + changed files + the prompt)
    # and invokes the provider as `command REQUEST_FILE OUTPUT_FILE`.
    # The provider's output is validated (bullets only, no preamble,
    # max 15 bullets) before it replaces the local body in CHANGELOG.md.
    # See examples/release-notes-providers/example-provider.sh for the
    # contract; any LLM (Claude, GPT, local model) works.
    provider: "local"       # local (use built-in generator) | command
    command: ""             # Path to provider script
    required: false         # If true, provider failure aborts the ship

# -----------------------------------------------------------------------------
# Trusted Timestamps (HTTPS)
# -----------------------------------------------------------------------------
time:
  server1: "https://www.cloudflare.com/cdn-cgi/trace"
  server2: "https://www.google.com/generate_204"
  server3: "https://www.apple.com"
  server4: ""
  timeout: 5
  retries: 3
  verify: true
  cache_ttl: 120
  cache_cleanup_period: 3600
  cache_stale_max_age: 21600
  timezone: "UTC"

# -----------------------------------------------------------------------------
# Files and Directories
# -----------------------------------------------------------------------------
files:
  readme: "README.md"
  version: "VERSION"
  gitignore: ".gitignore"
  archive_dir: "zArchive"
  git_dir: ".git"
  modules_dir: "modules"
  markdown_ext: "*.md"

# -----------------------------------------------------------------------------
# Auto-Update
# -----------------------------------------------------------------------------
auto_update:
  enabled: true
  cooldown: 30

# -----------------------------------------------------------------------------
# Homebrew (macOS)
# -----------------------------------------------------------------------------
brew:
  option: "enabled"
  interactive: "no"
  tap_repo: "https://github.com/fidenceio/homebrew-tap.git"

# -----------------------------------------------------------------------------
# Project Metadata
# -----------------------------------------------------------------------------
project:
  name: ""
  description: ""
  organization: ""
  team: ""

# -----------------------------------------------------------------------------
# Fleet
# -----------------------------------------------------------------------------
fleet:
  mode: "auto"                       # auto | true | false
  root: ""                           # Optional explicit fleet root.
  config_filename: "manifest.fleet.config.yaml"
  name: ""                           # Repo-local identity hint.
  member: ""                         # Repo-local identity hint.

# -----------------------------------------------------------------------------
# Automation
# -----------------------------------------------------------------------------
automation:
  auto_confirm: false                # Prompt automation only; does not imply -y.

# -----------------------------------------------------------------------------
# Deprecations
# -----------------------------------------------------------------------------
deprecations:
  quiet: false

# -----------------------------------------------------------------------------
# Network
# -----------------------------------------------------------------------------
network:
  offline: false

# -----------------------------------------------------------------------------
# Cloud
# -----------------------------------------------------------------------------
cloud:
  skip: false
  api_key_env: "MANIFEST_CLI_CLOUD_API_KEY"  # Name of env var that holds the secret.

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
security:
  private_files: ".env,.env.development,.env.test,.env.production,.env.staging,manifest.config.local.yaml"

# -----------------------------------------------------------------------------
# Debugging
# -----------------------------------------------------------------------------
debug:
  enabled: false
  verbose: false
  log_level: "INFO"
  interactive: false

# -----------------------------------------------------------------------------
# Pull Requests
# -----------------------------------------------------------------------------
pr:
  profile: "solo"              # solo | team | regulated
  enforce_ready: true

# -----------------------------------------------------------------------------
# Config
# -----------------------------------------------------------------------------
config:
  schema_version: 2
