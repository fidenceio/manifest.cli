# =============================================================================
# 🚀 Manifest CLI Global Environment Configuration
# =============================================================================
# Copy this file to .env.manifest.global and customize for your needs:
#   cp env.manifest.global.example .env.manifest.global
#
# 📋 CONFIGURATION PRECEDENCE (last wins):
#   1. .env.manifest.global (global configuration - commit to git)
#   2. .env.manifest.local (project-specific overrides - DO NOT commit to git)
#
# 💡 QUICK START: 
#   • Global setup: Uncomment variables in "Essential" section below
#   • Project overrides: Copy env.manifest.local.example to .env.manifest.local in your project
#   • Test setup: Run 'manifest test' to verify your configuration
# =============================================================================

# =============================================================================
# 🎯 ESSENTIAL CONFIGURATION (Start Here)
# =============================================================================
# These are the most commonly customized settings. All variables below are already
# configured with sensible defaults - uncomment and modify only what you need.

# =============================================================================
# 📁 FILE AND DIRECTORY NAMES
# =============================================================================
# Customize file and directory names (advanced users only)

# MANIFEST_CLI_README_FILE="README.md"                 # README filename
# MANIFEST_CLI_VERSION_FILE="VERSION"                  # Version filename
# MANIFEST_CLI_GITIGNORE_FILE=".gitignore"             # Gitignore filename
# MANIFEST_CLI_DOCUMENTATION_ARCHIVE_DIR="zArchive"    # Documentation archive directory name
# MANIFEST_CLI_GIT_DIR=".git"                          # Git directory name
# MANIFEST_CLI_MODULES_DIR="modules"                   # Modules directory name

# =============================================================================
# 📄 FILE EXTENSIONS
# =============================================================================
# Customize file extensions (advanced users only)

# MANIFEST_CLI_MARKDOWN_EXT="*.md"                     # Markdown file extension

# =============================================================================
# 🏠 INSTALLATION PATHS
# =============================================================================
# Customize installation paths (advanced users only)

# MANIFEST_CLI_INSTALL_DIR="~/.manifest-cli"               # Install location (manual install only)
# MANIFEST_CLI_BIN_DIR="~/.local/bin"                       # Binary location (manual install only)

# =============================================================================
# 🗂️ TEMPORARY FILE PATHS
# =============================================================================
# Customize temporary file paths (advanced users only)

# MANIFEST_CLI_TEMP_DIR="~/.manifest-cli"              # Temp files directory
# MANIFEST_CLI_TEMP_LIST="temp-files.list"             # Temp files list filename

# =============================================================================
# ⚙️ CONFIGURATION FILE NAMES
# =============================================================================
# Customize configuration file names (advanced users only)

# MANIFEST_CLI_CONFIG_GLOBAL=".env.manifest.global"    # Global config filename
# MANIFEST_CLI_CONFIG_LOCAL=".env.manifest.local"      # Local config filename

# =============================================================================
# 🎮 INTERACTIVE MODE
# =============================================================================
# Control safety prompts during version bumps
# false = Non-interactive (default, good for CI/CD)
# true  = Interactive prompts (use -i flag instead)
MANIFEST_CLI_INTERACTIVE_MODE=false

# =============================================================================
# 📊 VERSIONING SYSTEM
# =============================================================================

# Version format pattern for your organization
# Examples:
#   "XX.XX.XX"     → 1.0.0 (standard semantic versioning)
#   "XXXX.XXXX.XXXX" → 0001.0001.0001 (enterprise with zero-padding)
#   "X.X.X.X"      → 1.0.0.1 (with build number)
#   "YYYY.MM.DD"   → 2024.01.15 (date-based versioning)
MANIFEST_CLI_VERSION_FORMAT=XX.XX.XX

# Version separator character
MANIFEST_CLI_VERSION_SEPARATOR=.

# Version component names (for documentation)
MANIFEST_CLI_VERSION_COMPONENTS=major,minor,patch

# Maximum version component values (0 = unlimited)
# Format: "major_max,minor_max,patch_max"
MANIFEST_CLI_VERSION_MAX_VALUES=0,0,0

# =============================================================================
# 🧠 HUMAN-INTUITIVE VERSIONING LOGIC
# =============================================================================
# LEFT components = More MAJOR changes (bigger impact)
# RIGHT components = More MINOR changes (smaller impact)

# Which component represents each type of change:
MANIFEST_CLI_MAJOR_COMPONENT_POSITION=1
MANIFEST_CLI_MINOR_COMPONENT_POSITION=2
MANIFEST_CLI_PATCH_COMPONENT_POSITION=3
MANIFEST_CLI_REVISION_COMPONENT_POSITION=4

# =============================================================================
# 📈 VERSION INCREMENT BEHAVIOR
# =============================================================================
# When you run "manifest prep major" - which component increments?
MANIFEST_CLI_MAJOR_INCREMENT_TARGET=1

# When you run "manifest prep minor" - which component increments?
MANIFEST_CLI_MINOR_INCREMENT_TARGET=2

# When you run "manifest prep patch" - which component increments?
MANIFEST_CLI_PATCH_INCREMENT_TARGET=3

# When you run "manifest prep revision" - which component increments?
MANIFEST_CLI_REVISION_INCREMENT_TARGET=4

# =============================================================================
# 🔄 VERSION RESET BEHAVIOR
# =============================================================================
# When incrementing MAJOR, reset these components to 0
MANIFEST_CLI_MAJOR_RESET_COMPONENTS=2,3,4

# When incrementing MINOR, reset these components to 0
MANIFEST_CLI_MINOR_RESET_COMPONENTS=3,4

# When incrementing PATCH, reset these components to 0
MANIFEST_CLI_PATCH_RESET_COMPONENTS=4

# When incrementing REVISION, reset these components to 0
MANIFEST_CLI_REVISION_RESET_COMPONENTS=

# =============================================================================
# 🏷️  GIT CONFIGURATION
# =============================================================================

# Git tag prefix and suffix
MANIFEST_CLI_GIT_TAG_PREFIX=v
MANIFEST_CLI_GIT_TAG_SUFFIX=

# Git operation settings
MANIFEST_CLI_GIT_PUSH_STRATEGY=simple
MANIFEST_CLI_GIT_PULL_STRATEGY=rebase
MANIFEST_CLI_GIT_TIMEOUT=300
MANIFEST_CLI_GIT_RETRIES=3

# Custom commit message template
# Available placeholders: {version}, {timestamp}, {type}, {branch}
MANIFEST_CLI_GIT_COMMIT_TEMPLATE=Release v{version} - {timestamp}

# =============================================================================
# 🌿 BRANCH NAMING CONVENTION
# =============================================================================

MANIFEST_CLI_GIT_DEFAULT_BRANCH=main
MANIFEST_CLI_GIT_FEATURE_BRANCH_PREFIX=feature/
MANIFEST_CLI_GIT_HOTFIX_BRANCH_PREFIX=hotfix/
MANIFEST_CLI_GIT_RELEASE_BRANCH_PREFIX=release/
MANIFEST_CLI_GIT_BUGFIX_BRANCH_PREFIX=bugfix/
MANIFEST_CLI_GIT_DEVELOPMENT_BRANCH=develop
MANIFEST_CLI_GIT_STAGING_BRANCH=staging

# =============================================================================
# 📚 DOCUMENTATION CONFIGURATION
# =============================================================================

# Documentation folder paths (relative to project root)
MANIFEST_CLI_DOCS_FOLDER=docs
MANIFEST_CLI_DOCS_ARCHIVE_FOLDER=docs/zArchive

# Documentation settings
MANIFEST_CLI_DOCS_AUTO_GENERATE=true
MANIFEST_CLI_DOCS_HISTORICAL_LIMIT=20

# Documentation file naming pattern
# Available placeholders: VERSION
# Examples:
#   "RELEASE_vVERSION.md" → RELEASE_v1.0.0.md
#   "RELEASE_VERSION.md"  → RELEASE_1.0.0.md
MANIFEST_CLI_DOCS_FILENAME_PATTERN=RELEASE_vVERSION.md

# Custom template directory (leave empty for built-in templates)
MANIFEST_CLI_DOCS_TEMPLATE_DIR=

# =============================================================================
# 🕐 TRUSTED TIMESTAMPS (NTP)
# =============================================================================

# NTP servers for trusted timestamps
MANIFEST_CLI_NTP_SERVER1=time.apple.com
MANIFEST_CLI_NTP_SERVER2=time.google.com
MANIFEST_CLI_NTP_SERVER3=pool.ntp.org
MANIFEST_CLI_NTP_SERVER4=time.nist.gov

# NTP operation settings
MANIFEST_CLI_NTP_TIMEOUT=5
MANIFEST_CLI_NTP_RETRIES=3
MANIFEST_CLI_NTP_VERIFY=true

# =============================================================================
# 🌍 TIMEZONE CONFIGURATION
# =============================================================================
# Timezone for timestamp display (defaults to UTC)
# Use IANA timezone names (also known as "Olson" or "tz database" names)
#
# Examples:
#   UTC                  → Coordinated Universal Time (default)
#   America/New_York     → Eastern Time (US)
#   America/Los_Angeles  → Pacific Time (US)
#   America/Chicago      → Central Time (US)
#   America/Denver       → Mountain Time (US)
#   Europe/London        → British Time
#   Europe/Paris         → Central European Time
#   Europe/Berlin        → Central European Time
#   Asia/Tokyo           → Japan Standard Time
#   Asia/Shanghai        → China Standard Time
#   Asia/Kolkata         → India Standard Time
#   Australia/Sydney     → Australian Eastern Time
#
# Override in .env.manifest.local for project-specific timezone
MANIFEST_CLI_TIMEZONE=UTC

# =============================================================================
# 🔄 AUTO-UPDATE CONFIGURATION
# =============================================================================

MANIFEST_CLI_AUTO_UPDATE=true
MANIFEST_CLI_UPDATE_COOLDOWN=30

# =============================================================================
# 🍺 HOMEBREW INTEGRATION (macOS)
# =============================================================================

MANIFEST_CLI_BREW_OPTION=enabled
MANIFEST_CLI_BREW_INTERACTIVE=no
MANIFEST_CLI_TAP_REPO=https://github.com/fidenceio/homebrew-tap.git

# =============================================================================
# 🐛 DEVELOPMENT & DEBUGGING
# =============================================================================

MANIFEST_CLI_DEBUG=false
MANIFEST_CLI_VERBOSE=false
MANIFEST_CLI_LOG_LEVEL=INFO

# =============================================================================
# 🏢 PROJECT-SPECIFIC CONFIGURATION
# =============================================================================
# Add project-specific variables here
# These will be loaded when running manifest commands in this project

# Examples:
# MANIFEST_CLI_PROJECT_NAME="My Awesome Project"
# MANIFEST_CLI_PROJECT_DESCRIPTION="A revolutionary tool for developers"
# MANIFEST_CLI_TEAM_NAME="Development Team"
# MANIFEST_CLI_ORGANIZATION="Acme Corp"

# =============================================================================
# ⚙️  ADVANCED CONFIGURATION
# =============================================================================

# Custom version parsing regex (leave empty for default)
MANIFEST_CLI_VERSION_REGEX=

# Custom version validation rules (leave empty for default)
MANIFEST_CLI_VERSION_VALIDATION=

# =============================================================================
# 📝 QUICK EXAMPLES
# =============================================================================
# 
# 🎯 Standard Open Source: Use defaults (already configured above)
# 🎯 Enterprise with Zero-Padding: Change VERSION_FORMAT to "XXXX.XXXX.XXXX"
# 🎯 Date-Based Versioning: Change VERSION_FORMAT to "YYYY.MM.DD"
# 🎯 Project-Specific: Copy env.manifest.local.example to .env.manifest.local
#
# =============================================================================
# 🔧 TROUBLESHOOTING
# =============================================================================
#
# ❌ Problem: Configuration not loading
# ✅ Solution: Check file permissions and syntax
#
# ❌ Problem: Project-specific settings not working
# ✅ Solution: Ensure .env.manifest.local is in project root
#
# ❌ Problem: Version format not working
# ✅ Solution: Test with 'manifest test versions'
#
# ❌ Problem: Documentation not generating
# ✅ Solution: Check MANIFEST_CLI_DOCS_AUTO_GENERATE=true
#
# =============================================================================
# 📚 FURTHER READING
# =============================================================================
# • User Guide: Run 'manifest --help' for command reference
# • Examples: Check docs/EXAMPLES.md for usage patterns
